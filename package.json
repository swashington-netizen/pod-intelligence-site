{
  "name": "pod-intelligence-site",
  "version": "1.0.0",
  "description": "Agentic Sales Productivity Portal - Full Stack Monorepo",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "install:all": "npm install && npm install --prefix frontend && npm install --prefix backend",
    "start:frontend": "cd frontend && npm start",
    "start:backend": "cd backend && npm run dev",
    "start": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && npm run build",
    "build": "npm run build:backend && npm run build:frontend",
    "test:frontend": "cd frontend && npm test",
    "test:backend": "cd backend && npm test",
    "test": "npm run test:backend && npm run test:frontend",
    "deploy:frontend": "cd frontend && npm run deploy",
    "deploy:backend": "cd backend && git push heroku main",
    "lint": "eslint frontend/src backend/src"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/swashington-netizen/pod-intelligence-site.git"
  },
  "keywords": [
    "salesforce",
    "agentic",
    "sales",
    "productivity",
    "portfolio",
    "dashboard"
  ],
  "author": "Steven Washington",
  "license": "UNLICENSED",
  "devDependencies": {
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0"
  }
}
